                  "placeholder": "EST_ENTER_PHONE_NUMBER",
                  "type": "text"
                },
                "validation": {
                  "maxLength": 10,
                  "pattern": "^[0-9]{10}$",
                  "regex": {
                    "pattern": "\\D",
                    "flags": "g"
                  },
                  "required": true,
                  "disabled": false,
                  "readOnly": false
                },
                "messages": {
                  "error": "EST_INVALID_PHONE_NUMBER"
