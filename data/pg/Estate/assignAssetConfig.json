                "validation": {
                  "required": true,
                  "disabled": false
                },
                "messages": {
                  "error": "EST_ALLOTMENT_TYPE_REQUIRED"
                }
              },
              {
                "order": 9,
                "key": "EST_ALLOTTEE_NAME",
                "field": {
                  "code": "EST_ALLOTTEE_NAME",
                  "name": "alloteeName",
                  "placeholder": "EST_ENTER_ALLOTTEE_NAME",
                  "type": "text"
                },
                "validation": {
                  "pattern": "^[a-zA-Z ]+$",
                  "regex": {
                    "pattern": "[^a-zA-Z ]",
                    "flags": "g"
                  },
                  "required": true,
                  "disabled": false,
                  "readOnly": false
                },
                "messages": {
                  "error": "EST_INVALID_ALLOTTEE_NAME"
