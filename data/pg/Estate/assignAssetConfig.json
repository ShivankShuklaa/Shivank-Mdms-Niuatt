                  "dataSource": {
                    "type": "MDMS",
                    "moduleName": "Estate",
                    "masterName": "AllotmentType"
                  }
                },
                "options": [
                  {
                    "code": "RENT",
                    "i18nKey": "EST_ALLOTMENT_TYPE_RENT"
                  },
                  {
                    "code": "LEASE",
                    "i18nKey": "EST_ALLOTMENT_TYPE_LEASE"
                  }
